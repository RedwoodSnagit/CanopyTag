{
  "name": "canopytag",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "vite",
    "dev:backend": "tsx watch src/backend/server.ts",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "init": "tsx src/cli/init.ts",
    "ls": "tsx src/cli/ls.ts",
    "health": "tsx src/cli/health.ts",
    "query": "tsx src/cli/query.ts",
    "stats": "tsx src/cli/stats.ts",
    "todos": "tsx src/cli/todos.ts",
    "context": "tsx src/cli/context.ts",
    "compare": "tsx src/cli/compare.ts",
    "coverage": "tsx src/cli/coverage.ts",
    "mcp": "tsx src/mcp/server.ts"
  },
  "bin": {
    "canopytag": "./bin/canopytag.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanstack/react-table": "^8.20.0",
    "fastify": "^5.0.0",
    "ignore": "^6.0.0",
    "react": "^18.3.0",
    "react-arborist": "^3.4.0",
    "react-dom": "^18.3.0",
    "sharp": "^0.34.5",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
